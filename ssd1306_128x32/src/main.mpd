import i2c::*
import gfx::*
import math::min
import rtos::*
import display::*
import drivers.ssd1306_128x32::*

const MESSAGE: u8[] = "Hello, world!"
const DISPLAY_CHARS: i32 = 15
const TOTAL_CHARS: i32 = 13
const INIT_LOCATION: i32 = 0 

fun main()
    // init I2C and open device
    val bus: i32 = i2c_init(I2C_BUS, I2C_SDA, I2C_SCL, I2C_FREQ)
    val dev: i32 = i2c_open(bus, OLED_ADDR)

    // wire display → gfx
    val conn: &DisplayConn = display_conn()
    conn.interface      = DisplayInterface.I2C
    conn.device         = dev
    conn.reset_pin      = -1
    conn.back_light_pin = -1
    display_attach_gfx(gfx_driver())
    gfx_init()

    gfx_clear(0)
    gfx_rect(0, 0, 128, 32, 1)

    var location: i32 = 0
    var first_char: i32 = 0
    var char_len: i32 = 0
    var x: i32 = 0
    while true
        gfx_fill_rect(1, 1, 126, 30, 0)
        if location < 0
            first_char = -location
            char_len = TOTAL_CHARS - first_char
            x = get_location_x(0)
        else
            first_char = 0
            char_len = min<i32>(DISPLAY_CHARS - location, TOTAL_CHARS)
            x = get_location_x(location)
        gfx_str(x, 12, {&MESSAGE[first_char], char_len}, 1, 0, 1)
        location -= 1
        if location < -TOTAL_CHARS + 1
            location = DISPLAY_CHARS - 1

        delay_ms(300)

@inline
fun get_location_x(char_location: i32) i32
    return char_location * 8 + 4